# Streamlit Community Cloud secrets template
# Copy these into the app's Secrets section when we deploy.

PHONE_NO = "your-phone-number"
MPIN = "your-mpin"
NUBRA_TOTP_SECRET = "your-base32-totp-secret"
# Optional one-time override for testing only
# NUBRA_OTP = "123456"
NUBRA_OI_WALLS_ENV = "PROD"
NUBRA_APP_ENV = "production"

# Supabase
SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_SECRET_KEY = "your-supabase-secret-key"
SUPABASE_DB_PASSWORD = "your-db-password"
SUPABASE_DB_HOST = "db.your-project-ref.supabase.co"
SUPABASE_DB_PORT = 5432
SUPABASE_DB_NAME = "postgres"
SUPABASE_DB_USER = "postgres"

# Optional direct Postgres URL
# SUPABASE_DB_URL = "postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres"

# Batch sync defaults
SCAN_SCHEDULER_ENABLED = true
SCAN_BATCH_SIZE = 50
SCAN_REFRESH_MINUTES = 10
SCAN_SYMBOL_SOURCE = "top_fno"
SCAN_SECTORS = ""
SCAN_SYMBOLS_CSV = ""

# Streamlit snapshot cache
STREAMLIT_CACHE_SECONDS = 45
